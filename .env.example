# Copy to `.env` and fill in real values. Used by docker-compose.remote.yml.
# (the app container reads these; `.env` itself is gitignored)

# --- Remote MySQL database the app connects to ---
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Offline login bypass (local/demo only). Set to 0 in real environments.
APP_LOCAL_AUTH=1

# Host ports
APP_PORT=8080
PALM_TWIN_PORT=5003

# URL the BROWSER uses to reach palm-twin (embedded in the Maps menu).
# Local: http://localhost:5003  |  Server: http://YOUR_PUBLIC_HOST:5003
PALM_TWIN_URL=http://localhost:5003
