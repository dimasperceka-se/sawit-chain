# Copy to `.env` and fill in real values. Used by docker-compose.remote.yml.
# (the app container reads these; `.env` itself is gitignored)

# --- Remote MySQL database the app connects to ---
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Offline login bypass (local/demo only). Set to 0 in real environments.
APP_LOCAL_AUTH=1

# Host ports (published on 127.0.0.1 only; reached via the nginx reverse proxy)
APP_PORT=8080
PALM_TWIN_PORT=5003

# Sub-path palm-twin is BUILT to serve under.
#   Local/standalone (served at root on :5003):   /
#   Behind reverse proxy at portal.sawitchain.com/twin:   /twin/
PALM_TWIN_BASE=/

# URL the BROWSER uses to reach palm-twin (iframe src in the Maps menu).
#   Local:                 http://localhost:5003
#   Reverse-proxy subpath: /twin   (relative; resolves to https://portal.sawitchain.com/twin)
PALM_TWIN_URL=http://localhost:5003
