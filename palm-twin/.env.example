# PostGIS-enabled Postgres containing tables: peatland_idn, palmoil_mill, plots_ady, twin_plots
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the app (API + client) is served on
PORT=5003

# Login gate — validated server-side (never commit real values)
AUTH_EMAIL=you@example.com
AUTH_PASSWORD=change-me

# --- Cron sync-compliance (server/jobs/sync-compliance.ts) ---
# Endpoint GeoJSON plot petani dari dashboard
DASHBOARD_GEOJSON_URL=https://portal.sawitchain.com/api/api_gis/plots/geojson
# Base URL API compliance eksternal
COMPLIANCE_API_BASE=https://global-compliance-system.com
